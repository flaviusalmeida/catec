# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL — docker compose na raiz do monorepo ou instância própria)
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/catec
SPRING_DATASOURCE_USERNAME=catec
SPRING_DATASOURCE_PASSWORD=catec

# -----------------------------------------------------------------------------
# E-mail
# -----------------------------------------------------------------------------
# Desenvolvimento com Mailpit: docker compose up -d na raiz → SMTP localhost:1025, UI http://localhost:8025
APP_MAIL_ENABLED=true
APP_MAIL_FROM=noreply@localhost
APP_FRONTEND_URL=http://localhost:3000

SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false

# Exemplo Gmail (senha de app — https://myaccount.google.com/apppasswords):
# APP_MAIL_FROM=seu@gmail.com
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=seu@gmail.com
# SPRING_MAIL_PASSWORD="xxxx xxxx xxxx xxxx"
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS=true

# -----------------------------------------------------------------------------
# Opcional
# -----------------------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=dev
# JWT_SECRET=catec-dev-jwt-secret-min-32b-please-change!!
