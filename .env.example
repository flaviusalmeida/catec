# PostgreSQL (Docker Compose + referência para o backend)
# Banco, usuário e senha: catec / catec / catec (apenas desenvolvimento local)
POSTGRES_DB=catec
POSTGRES_USER=catec
POSTGRES_PASSWORD=catec
POSTGRES_PORT=5432

# Conexão JDBC — Spring Boot (copie para .env na raiz; ajuste a porta se mudar POSTGRES_PORT)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/catec
SPRING_DATASOURCE_USERNAME=catec
SPRING_DATASOURCE_PASSWORD=catec

# E-mail (opcional). Com APP_MAIL_ENABLED=false o backend registra a senha provisória no log (apenas desenvolvimento).
APP_MAIL_ENABLED=false
APP_MAIL_FROM=noreply@catec.local
# Se ativar envio real, configure também spring.mail.* (ex.: host/porta SMTP).
